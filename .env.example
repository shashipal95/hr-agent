# ── Copy this file to .env and fill in your values ────────────
# NEVER commit .env to git — it is already in .gitignore

# Groq LLM (free) → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini Embeddings (free) → https://aistudio.google.com
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone Vector Store (free) → https://pinecone.io
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_ENV=us-east-1

# Pinecone index names (do not change unless you recreate them)
PINECONE_POLICY_INDEX=hr-policy-index
PINECONE_EMPLOYEE_INDEX=hr-index

# CORS — comma-separated list of allowed frontend origins
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000
# Production (set this in Railway dashboard, not here):
# ALLOWED_ORIGINS=https://yourportfolio.vercel.app,https://www.yourportfolio.com

# App environment
APP_ENV=development
LOG_LEVEL=INFO
